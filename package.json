{
  "name": "nexus-notes-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev:web": "pnpm --filter @nexus-notes/web dev",
    "dev:desktop": "pnpm --filter @nexus-notes/desktop dev",
    "build:all": "pnpm --filter @nexus-notes/web generate && pnpm -r build",
    "test:all": "pnpm -r test",
    "lint:all": "pnpm -r lint",
    "typecheck:all": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

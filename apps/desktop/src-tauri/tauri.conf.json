{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri-json-schema/refs/heads/main/tauri.conf.json",
  "productName": "NexusNotes",
  "version": "0.0.0",
  "identifier": "com.nexus-notes.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @nexus-notes/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @nexus-notes/web generate",
    "frontendDist": "../../web/.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "NexusNotes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
